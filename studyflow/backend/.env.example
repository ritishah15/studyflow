# ── Server ──────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT ──────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_also_change_this_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ── Database ─────────────────────────────
# SQLite — file path relative to project root
DB_PATH=./data/studyflow.db

# ── Anthropic Claude API ─────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# ── Razorpay (Sandbox) ───────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── CORS ─────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# ── File Uploads ─────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── Rate Limiting ────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20
